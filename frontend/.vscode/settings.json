{
  "workbench.colorTheme": "One Dark Pro",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.fontFamily": "Fira Code, 'Courier New', monospace",
  "editor.tokenColorCustomizations": {
    "comments": "#6B7280",
    "strings": "#64B725",
    "numbers": "#F1701D",
    "keywords": "#F1701D"
  },
  "workbench.colorCustomizations": {
    "editor.background": "#FEFEFE",
    "editor.foreground": "#1F2937",
    "editor.lineNumberColor": "#CAD0DC",
    "editor.lineHighlightBackground": "#F4F8FB",
    "editor.selectionBackground": "#F1701D20",
    "editor.findMatchBackground": "#64B72540",
    "editor.findMatchBorder": "#64B725",
    "editorCursor.foreground": "#F1701D",
    "editorCursor.background": "#FEFEFE",
    "editorWhitespace.foreground": "#E5E7EB",
    "editorIndentGuide.background": "#E6E8EC",
    "editorIndentGuide.activeBackground": "#F1701D",
    "editorBracketMatch.background": "#64B72530",
    "editorBracketMatch.border": "#64B725",
    "editorError.foreground": "#EF4444",
    "editorWarning.foreground": "#F59E0B",
    "editorInfo.foreground": "#3B82F6",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeBorder": "#F1701D",
    "tab.inactiveBackground": "#F4F8FB",
    "tab.inactiveForeground": "#6B7280",
    "editorGroupHeader.tabsBackground": "#FEFEFE",
    "sideBar.background": "#F4F8FB",
    "sideBar.foreground": "#1F2937",
    "sideBar.border": "#E6E8EC",
    "sideBarTitle.foreground": "#1F2937",
    "sideBarSectionHeader.background": "#F1F7FB",
    "sideBarSectionHeader.foreground": "#1F2937",
    "list.hoverBackground": "#F1F7FB",
    "list.activeSelectionBackground": "#F1701D20",
    "list.activeSelectionForeground": "#1F2937",
    "statusBar.background": "#FEFEFE",
    "statusBar.foreground": "#1F2937",
    "statusBar.border": "#E6E8EC",
    "statusBar.debuggingBackground": "#F59E0B",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.noFolderBackground": "#F4F8FB",
    "titleBar.activeBackground": "#FEFEFE",
    "titleBar.activeForeground": "#1F2937",
    "titleBar.border": "#E6E8EC",
    "focusBorder": "#F1701D",
    "button.background": "#F1701D",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#E65F00",
    "textLink.foreground": "#F1701D",
    "textLink.activeForeground": "#E65F00",
    "inputBox.background": "#FFFFFF",
    "inputBox.foreground": "#1F2937",
    "inputBox.border": "#E6E8EC",
    "inputBox.focusBorder": "#64B725",
    "dropdown.background": "#FFFFFF",
    "dropdown.foreground": "#1F2937",
    "dropdown.border": "#E6E8EC",
    "menu.background": "#FFFFFF",
    "menu.foreground": "#1F2937",
    "menu.separatorBackground": "#E6E8EC"
  },
  "tailwindCSS.includeLanguages": {
    "javascript": "javascript",
    "typescript": "typescript",
    "javascriptreact": "html",
    "typescriptreact": "html"
  },
  "tailwindCSS.emmetCompletions": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  }
}
